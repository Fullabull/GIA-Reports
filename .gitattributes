* text=auto

# Code files
#   - Python scripts: do not normalize (store exactly as-is)
#   - Everything else: normalize to LF for consistency
*.py    -text
*.sh    text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.vim   text eol=lf

# Windows scripts (keep CRLF in working tree)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Text & JSON — do not normalize
*.txt   text eol=lf
*.json  text eol=lf

# Binary — never modify line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.mp3   binary
*.wav   binary
*.zip   binary
*.7z    binary
